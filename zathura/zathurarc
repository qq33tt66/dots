# === Appearance ===
set font "Inter 11"
# set default-bg "#15161e"
# set default-fg "#c0caf5"
set statusbar-bg "#1a1b26"
set statusbar-fg "#c0caf5"
set inputbar-bg "#1a1b26"
set inputbar-fg "#c0caf5"
set notification-bg "#1a1b26"
set notification-fg "#c0caf5"
set notification-error-bg "#1a1b26"
set notification-error-fg "#f7768e"
set notification-warning-bg "#1a1b26"
set notification-warning-fg "#ff9e64"
# set highlight-color "#e0af68"
# set highlight-active-color "#9ece6a"
set completion-bg "#292e42"
set completion-fg "#c0caf5"
set completion-highlight-bg "#283457"
set completion-highlight-fg "#c0caf5"
set recolor-lightcolor "#edd1b0"
set recolor-darkcolor "#000000"

# === Behavior ===
set pages-per-row 1
set page-padding 4
set scroll-step 50
set zoom-min 10
set zoom-max 1000
set zoom-step 10
set statusbar-home-tilde true
set selection-clipboard clipboard
set window-title-basename true
set window-title-page true
set adjust-open "best-fit"
set render-loading true
# set render-loading-fg "#c0caf5"
# set render-loading-bg "#15161e"

# recolor (dark mode) off by default, toggle with 'r'
set recolor false
set recolor-keephue false

# === Keybindings ===
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r recolor
map R rotate
map i revert-video
map <C-b> toggle_statusbar
